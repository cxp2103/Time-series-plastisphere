rm(list=ls())#clear Global Environment


# Load required R packages
library(igraph)
library(Hmisc)

# Packages required for calculating network parameters and node attributes
library(phyloseq)
library(ggClusterNet)
library(tidyverse)
library(Biostrings)

library(ggplot2)# Plotting
###########################################################################################################
###########################################################################################################
# Input the family-level abundance table
otu <- read.delim(file="Family_GB2.txt", sep="\t", header=T, check.names=F, row.names = 1)


# Filter out families detected in less than 10% of samples
otu_A<- otu[which(apply(otu, 1, function(x) sum(x>0))>=(ncol(otu)/10)), ]


# Calculate Spearman correlation coefficients
sp.cor<- rcorr(t(otu_A),type="spearman")

# Extract the correlation coefficient matrix and P-value matrix
r.cor<-sp.cor$r
p.cor<-sp.cor$P

# Adjust P values for multiple testing using the Benjamini-Hochberg method
p.adj <- p.adjust(p.cor, method="BH")

# Set thresholds for potential species interactions.
# Correlations not meeting the thresholds are converted to 0.
r.cor[p.cor>=0.05|abs(r.cor)<0.6] = 0


# Set locale to avoid potential errors in the following steps
Sys.setlocale('LC_ALL','C')


# Remove self-correlations on the diagonal
diag(r.cor) <- 0

# Remove isolated nodes from the filtered correlation matrix.
# Rows and columns with all zero correlations are removed.
# If only occurrence-frequency filtering is required, the following two lines can be skipped.
r.cor=r.cor[which(rowSums(abs(r.cor)) > 0),] # Keep rows with an absolute row sum greater than 0
r.cor=r.cor[,which(colSums(abs(r.cor)) > 0)] # Keep columns with an absolute column sum greater than 0

# Optional: set within-category correlations to 0 if cross-category networks are required
#r.cor[1:1152, 1:1152] <-0
#r.cor[1153:1975, 1153:1975] <-0
#r.cor[1976:2049, 1976:2049] <-0

write.table (r.cor,file="correlation_coefficients_GB2.txt", sep="\t", quote =T,col.names = NA)

# Check the dimensions and the first few rows/columns of the filtered matrix
dim(r.cor)
r.cor[1:10,1:10]

# Create a network using the adjacency matrix, namely the correlation coefficient matrix
A<-graph.adjacency(r.cor,weight=T,mode="undirected")

# Remove redundant edges, including multiple edges and loop edges
A<-simplify(A)

# Extract edge weights
df_weight = E(A)$weight
# Set edge width according to the absolute value of the correlation coefficient
E(A)$width = abs(df_weight)*5      # E(A) represents the edge matrix of network A

# Add family-level abundance information
data <- rowSums(otu_A)
data1=as.data.frame(data)
df_igraph_size <- data1[V(A)$name, ] # Extract the corresponding family attributes; V(A) represents the node matrix of network A
df_igraph_size2 = log10(df_igraph_size)# Transform the abundance data
V(A)$Abundance = df_igraph_size2    

# Add taxonomic information and use different colors to represent taxa
data2=read.delim(file="Network_ASVs_tax.txt",sep="\t",header=T,
                 check.names=FALSE,row.names = 1)
df_igraph_col = data2[V(A)$name,]
V(A)$G = as.character(df_igraph_col$Tax_Genus)
# Optional: use a taxonomy table containing kingdom, phylum, class, order, family, and genus information
# Generate node labels and calculate node degree
V(A)$label <-  V(A)$name
V(A)$degree <- degree(A)
# Check the structure of the network object
print(A)

# Calculate node modularity-related properties and visualize node roles
result = nodeEdge(cor = r.cor) # Generate node and edge information from the correlation matrix

# Extract the edge table
edge = result[[1]]
E(A)$pn <- as.character(edge$direction) # Add positive or negative edge direction information for plotting

# Extract the node table
node = result[[2]]
igraph  = igraph::graph_from_data_frame(edge, directed = FALSE, vertices = node) # This assignment makes the igraph object equivalent to network A above
res = ZiPiPlot(igraph = igraph,method = "cluster_fast_greedy")# Calculate Zi and Pi; this step can be slow
p <- res[[1]] # Plot
ZiPi<-res[[2]] # Data table; columns Z and P represent Zi and Pi, and Module indicates module ID
ZiPi$Genus<-rownames(ZiPi)

# Export the network as graphml format for further visualization in Gephi
write_graph(A, "Family_GB2.graphml", format="graphml")

# Calculate network properties and node attributes using ggClusterNet
dat = net_properties(A)# Required before running net_properties.2
dat = net_properties.2(A,n.hub = T)# This step can be slow

# Calculate node properties
nodepro <- node_properties(A)

# Add taxonomy information from "Network_tax.txt" and hub-related information to the node property table
nodepro <-as.data.frame(nodepro)# Convert to a data frame to allow adding new columns
nodepro$Genus<-rownames(nodepro)
nodepro$id<-1:nrow(nodepro)# Add an ID column according to row order
nodepro<-merge(nodepro,ZiPi,by="Genus")# Add Zi and Pi information from the ZiPi table
df_igraph_col$Genus <- rownames(df_igraph_col)
nodepro <- merge(nodepro, df_igraph_col, by="Genus")
nodepro <- nodepro[order(nodepro$id), ]# Restore the original order according to the ID column
write.table (dat, file ="network_properties_GB2.txt",sep ="\t", quote =F,col.names = NA)
write.table (nodepro, file ="node_properties_GB2.txt",sep ="\t", quote =F,col.names = NA)

# Identify key families by ranking hub scores.
# Hub information above is more related to Zi-Pi-based node roles.
hub = hub_score(A)$vector %>% #
  sort(decreasing = TRUE) %>%
  head(10000) %>%       # Select the top 10,000 nodes to include as many nodes as possible
  as.data.frame()
colnames(hub) = "hub_sca"
ggplot(hub) +
  geom_bar(aes(x = hub_sca,y = reorder(row.names(hub),hub_sca)),stat = "identity",fill = "#4DAF4A")
write.table (hub, file ="hub_sca_Family_GB2.txt",sep ="\t", quote =F,col.names = NA)
# Construct random networks and compare network parameters
result = random_Net_compate(igraph = igraph, type = "gnm", step = 100, netName = layout) # This step can be slow
p1 = result[[1]] # Plot comparing the empirical network with random networks
p1
net = result[[2]]# Information table for the random network comparison
sum_net = result[[4]] # Summary table of random network parameters
ggsave(p1,filename = "Family_GB2.png",width = 8,height = 8)
write.table (net, file ="Table_Family_GB2.txt",sep ="\t", quote =F,col.names = NA)
write.table (sum_net, file ="Summary_Family_GB2.txt",sep ="\t", quote =F,col.names = NA)

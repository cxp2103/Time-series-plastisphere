rm(list=ls())#clear Global Environment

library(ggplot2)
############## Compare node properties #############
# Read node property data
df1 <- read.delim("node_properties_PE8.txt",header = T, check.names = F, row.names=1)

# Add node abundance information
r1<- read.delim("spieces_PE8.txt",header = T, check.names = F)

# Remove ASVs that were excluded from the network analysis
r1 <- r1[(r1[,1] %in% df1$Genus), ]

# This part is consistent with the script used for Hub-Relative abundance analysis
rownames(r1)=r1[,1]# Set the first column as row names
r1<-r1[ ,-c(1)] # Remove the first column containing Genus information
                        
# Calculate connectivity and cohesion metrics for the PE8 network
# Read the species abundance table
spe =r1

# Read the network adjacency matrix
g <- read.delim('correlation_coefficients_PE8.txt', row.names = 1, sep = '\t', check.names = FALSE)

# Calculate positive and negative connectivity for each species
r_pos <- c()
r_neg <- c()
spe_i <- c()

for (i in names(g)) {
    co <- na.omit(g[[i]])
    r_pos <- c(r_pos, mean(co[co>0]))
    r_neg <- c(r_neg, mean(co[co<0]))
    spe_i <- c(spe_i, i)
}
r <- data.frame(spe_i, r_pos, r_neg)
r
# Replace NaN values with 0. NaN values occur when a node has no positive or negative connectivity,  which can affect subsequent cohesion calculations.
r[is.na(r)] <- 0

# Calculate positive and negative cohesion for each sample
C_pos <- c()
C_neg <- c()
sample <- c()

for (j in names(spe)) {
    C_pos <- c(C_pos, sum(spe[[j]]*r$r_pos))
    C_neg <- c(C_neg, sum(spe[[j]]*r$r_neg))
    sample <- c(sample, j)
}
C <- data.frame(sample, C_pos, C_neg)
C$C_total<-C$C_pos+abs(C$C_neg)

# Export connectivity and cohesion results
write.table(r, 'Connectivity_PE8.txt', sep = '\t', row.names = FALSE, quote = FALSE)
write.table(C, 'Cohesion_PE8.txt', sep = '\t', row.names = FALSE, quote = FALSE)

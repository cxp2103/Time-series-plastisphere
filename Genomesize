# Activate the conda environment for EukRep
conda activate eukrep-env

# Use EukRep to separate eukaryotic and prokaryotic contigs from metagenomic contigs.
# PE8.contig.ok.fa is the input metagenomic contig file.
# PE8-euk.fa stores the predicted eukaryotic contigs.
# PE8-bact.fa stores the predicted prokaryotic contigs.
EukRep --min 500 -i PE8.contig.ok.fa -o PE8-euk.fa --prokarya PE8-bact.fa
conda deactivate

# Activate the conda environment for MicrobeCensus
conda activate metagenome

# Set the temporary directory for MicrobeCensus
export TMPDIR=/home/xpchen/Genomesize/MicrobeCensus-master/cxp_meta_genomesize/ 

# Estimate the average genome size.
# PE8-bact.fa is the input file generated by EukRep.
# PE8.genome_size is the output file containing the estimated average genome size.
run_microbe_census.py -t 50 \
-n 100000000 -e \
/home/xpchen/Genomesize/MicrobeCensus-master/bacteria_contigs/PE8-bact.fa \
/home/xpchen/Genomesize/MicrobeCensus-master/bacteria_genomesize/PE8.genome_size
